# StagePoster root layout
STAGEPOSTER_ROOT=/workspace/poster-engine
BACKEND_ROOT=/workspace/poster-engine/backend
COMFY_ROOT=/workspace/poster-engine/ComfyUI
COMFY_VENV=/workspace/poster-engine/venv
VLLM_VENV=/workspace/poster-engine/.venv-vllm

# Go backend
LISTEN_ADDR=:8080
DB_PATH=/workspace/poster-engine/backend/data/poster.db
STORAGE_ROOT=/workspace/poster-engine/backend/storage/jobs
ASSET_STORAGE_ROOT=/workspace/poster-engine/backend/storage/assets
POSTER_OUTPUT_ROOT=/workspace/poster-engine/backend/storage/posters
RECONCILE_INTERVAL=2s

# Optional API authentication
# Leave empty for local development only.
POSTER_API_TOKEN=

# ComfyUI
COMFY_URL=http://127.0.0.1:8188
COMFY_LISTEN=127.0.0.1
COMFY_PORT=8188

# ComfyUI workflow
WORKFLOW_PATH=/workspace/poster-engine/workflows/z_image_poster_v1.json
WORKFLOW_KEY=z_image_poster_v1
WORKFLOW_VERSION=1.0.0
PROMPT_NODE_ID=57:27
SEED_NODE_ID=57:3
NEGATIVE_PROMPT_NODE_ID=

# VLM service
VLM_URL=http://127.0.0.1:8001
VLM_HOST=127.0.0.1
VLM_PORT=8001
VLM_MODEL_PATH=/workspace/poster-engine/models/Qwen3.5-9B
VLM_MODEL=stageposter-vlm
VLM_API_KEY=change-this-local-key
VLM_REQUEST_TIMEOUT=5m
VLM_AUTO_SLEEP=true

# vLLM development endpoints are required by the current GPU
# sleep/wake memory coordinator. Never expose port 8001 publicly.
VLLM_SERVER_DEV_MODE=1
VLLM_ROCM_SLEEP_MEM_CHUNK_SIZE=256

# vLLM runtime limits
VLLM_DTYPE=float16
VLLM_MAX_MODEL_LEN=4096
VLLM_MAX_NUM_SEQS=1
VLLM_MAX_BATCHED_TOKENS=4096
VLLM_GPU_MEMORY_UTILIZATION=0.65

# Optional review testing image
REVIEW_IMAGE=

# Optional custom fonts
POSTER_FONT_REGULAR=
POSTER_FONT_BOLD=

# Hugging Face
# Only required for gated or authenticated model downloads.
HF_TOKEN=

# Development Cloudflare URL.
# This changes whenever a Quick Tunnel is recreated.
PUBLIC_API_URL=
